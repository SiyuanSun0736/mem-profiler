{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hotspot_summary",
  "title": "HotspotSummary",
  "description": "归因到进程/函数/地址区间的热点摘要，由 analysis/hotspot.py 或 analysis/attribution.py 生成。",
  "type": "object",
  "required": ["schema_version", "run_id", "symbol", "event_type", "count"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "run_id":         { "type": "string" },
    "pid":            { "type": "integer" },
    "comm":           { "type": "string" },
    "symbol": {
      "type": "string",
      "description": "函数名（P2+），或进程名（P1 占位）"
    },
    "dso": {
      "type": "string",
      "description": "所属可执行文件或共享库路径"
    },
    "start_addr":   { "type": "integer" },
    "end_addr":     { "type": "integer" },
    "source_file":  { "type": "string" },
    "source_line":  { "type": "integer" },
    "event_type": {
      "type": "string",
      "enum": ["llc_load_misses", "llc_store_misses", "dtlb_misses",
               "minor_faults", "major_faults", "anon_faults",
               "file_faults", "shared_faults", "private_faults",
               "write_faults", "instruction_faults", "mmap_calls",
               "munmap_calls", "mprotect_calls", "brk_calls"]
    },
    "count":    { "type": "integer", "minimum": 0 },
    "fraction": {
      "type": "number", "minimum": 0, "maximum": 1,
      "description": "占同类事件总计数的比例"
    },
    "window_range": {
      "type": "object",
      "properties": {
        "first_window_id": { "type": "integer" },
        "last_window_id":  { "type": "integer" }
      }
    }
  }
}
