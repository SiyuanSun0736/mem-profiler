{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "run_metadata",
  "title": "RunMetadata",
  "description": "每次采集 session 的元信息。每次运行向 run_metadata.jsonl 追加一条 start 记录和一条 end 记录。",
  "type": "object",
  "required": ["schema_version", "run_id", "start_ts_iso", "target_pid", "host_info"],
  "properties": {
    "schema_version": { "type": "string", "const": "2.0" },
    "run_id":         { "type": "string", "description": "UUID v4，标识本次采集 session" },
    "start_ts_iso":   { "type": "string", "format": "date-time" },
    "end_ts_iso":     { "type": ["string", "null"], "format": "date-time" },
    "target_pid":     { "type": "integer", "description": "0 = 采集所有进程" },
    "target_tid":     { "type": "integer", "description": "0 = 不过滤 TID" },
    "target_comm":    { "type": "string" },
    "aggregation_scope": { "type": "string", "enum": ["per_pid", "per_tid"] },
    "window_sec":     { "type": "number", "minimum": 0.001 },
    "sample_rate":    { "type": "integer", "minimum": 1,
                "description": "CLI 字段名保留为 sample_rate；实际语义是 perf sample_period（每 N 次事件触发一次）" },
    "collection_backend": { "type": "string" },
    "enabled_probes": {
      "type": "object",
      "properties": {
        "llc":   { "type": "boolean" },
        "dtlb":  { "type": "boolean" },
        "itlb":  { "type": "boolean" },
        "fault": { "type": "boolean" },
        "fault_classification": { "type": "boolean" },
        "lbr":   { "type": "boolean" },
        "mm_syscalls": { "type": "boolean" }
      }
    },
    "observations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["observation_id", "kind", "backend", "metrics", "scope", "multiplex"],
        "properties": {
          "observation_id": { "type": "string" },
          "kind": { "type": "string", "description": "例如 pmu_sampling / trace_hook / lbr_sampling" },
          "backend": { "type": "string", "description": "例如 bcc_perf_event / perf_event_open / libbpf" },
          "metrics": {
            "type": "array",
            "items": { "type": "string" }
          },
          "scope": { "type": "string" },
          "sample_period": { "type": "integer", "minimum": 1 },
          "perf_event": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "config": { "type": "string" }
            }
          },
          "group": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "role": { "type": "string" }
            }
          },
          "multiplex": {
            "type": "object",
            "required": ["mode", "scaling_fields"],
            "properties": {
              "mode": { "type": "string", "description": "例如 opaque_backend / time_enabled_running / not_applicable" },
              "scaling_fields": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "notes": { "type": "string" }
        }
      }
    },
    "host_info": {
      "type": "object",
      "required": ["hostname", "kernel_version"],
      "properties": {
        "hostname":       { "type": "string" },
        "kernel_version": { "type": "string" },
        "cpu_model":      { "type": "string" },
        "num_cpus":       { "type": "integer" }
      }
    },
    "binary_path":   { "type": "string" },
    "binary_sha256": { "type": "string" },
    "notes":         { "type": "string" }
  }
}
